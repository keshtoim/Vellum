<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <connectionStrings>
    <add name="PublishingDB"
         connectionString="Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=PublishingHouse01;Integrated Security=True;Connect Timeout=30;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
</configuration>
